# ============================================================================
#  WorkHive — Social Auto-Publisher credentials
#  ---------------------------------------------------------------------------
#  THIS IS THE ONLY FILE YOU TOUCH.
#
#  1. Copy this file to:  social_accounts.env   (drop the ".example")
#     (video_marketing.bat does this for you on first run and opens it.)
#  2. Paste whatever tokens you have below. Leave the rest BLANK.
#  3. Save. That's it. The publisher posts to every platform you filled in
#     and quietly SKIPS every one you left blank.
#
#  Two kinds of platforms:
#    * AUTO  — paste a token here ONCE, it posts 100% by itself, zero clicks.
#    * ASSIST — needs NO token. The tool just opens the upload page with your
#               video attached + the caption already copied to your clipboard,
#               so all you do is hit "Post". (Used for the platforms whose
#               auto-posting would risk your real brand account.)
#
#  social_accounts.env is GIT-IGNORED — your tokens never leave this machine
#  and are never committed. (This .example file is safe to commit; it has no
#  secrets.)
# ============================================================================


# ── GLOBAL SAFETY SWITCH ────────────────────────────────────────────────────
# dry_run = build + validate everything and SHOW what would be posted, but do
#           NOT actually post to any AUTO platform. (ASSIST platforms still
#           open the browser — that's harmless, nothing posts until you click.)
# live    = actually post to the AUTO platforms.
# Start on dry_run. Flip to live once you've seen one dry run look right.
SOCIAL_PUBLISH_MODE=dry_run


# ════════════════════════════════════════════════════════════════════════════
#  FACEBOOK PAGE   —   AUTO   (posts your video + caption + first comment)
# ════════════════════════════════════════════════════════════════════════════
# What you paste: your Page's numeric ID + a LONG-LIVED Page access token.
#
# HOW TO GET THEM (one-time, ~5 minutes, free — you only need a Page you admin):
#   1. Go to  https://developers.facebook.com/  -> My Apps -> Create App
#      -> "Business" type. (You're the only user; no App Review needed to post
#       to a Page YOU admin.)
#   2. Open the Graph API Explorer:
#      https://developers.facebook.com/tools/explorer/
#   3. Top-right: pick your app. Click "Generate Access Token". In the
#      permission picker add ALL FOUR:  pages_show_list, pages_read_engagement,
#      pages_manage_posts, pages_manage_engagement  (the last one lets the
#      tool post the first comment). Approve the popup for your Page.
#   4. That gives a SHORT-lived USER token. Make it a LONG-lived PAGE token:
#        a. Paste the user token into the Access Token Debugger:
#           https://developers.facebook.com/tools/debug/accesstoken/
#           -> "Extend Access Token" (now ~60-day user token).
#        b. Back in Graph API Explorer, GET:  me/accounts
#           The "access_token" next to your Page in that response is your
#           LONG-LIVED PAGE TOKEN (it effectively does not expire while the
#           user token is valid). The "id" next to it is your FB_PAGE_ID.
#   5. Paste both below.
#
# (If you'd rather not do the developer-app step at all, just leave these BLANK
#  and add your Page URL under FACEBOOK GROUPS-style ASSIST below — the tool
#  will open your Page composer with the video + caption ready instead.)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# Which rendered aspect to post to the Page feed: 1x1 (square, best for feed),
# 16x9 (wide), or 9x16 (vertical / posts as a Reel). Default 1x1.
FB_PAGE_ASPECT=1x1


# ════════════════════════════════════════════════════════════════════════════
#  FACEBOOK GROUPS   —   ASSIST   (no token; groups ban auto-link-posting)
# ════════════════════════════════════════════════════════════════════════════
# Paste the URLs of the groups you want to post to, comma-separated. The tool
# opens each group's composer, puts the group-version caption on your clipboard,
# and reveals the video file so you just attach + paste + post.
# Example: https://www.facebook.com/groups/psmeph,https://www.facebook.com/groups/iieeph
FB_GROUP_URLS=


# ════════════════════════════════════════════════════════════════════════════
#  YOUTUBE  (long-form + Shorts)   —   ASSIST by default, AUTO if you opt in
# ════════════════════════════════════════════════════════════════════════════
# YT_MODE=assist  -> opens studio.youtube.com upload with the 16x9 (long-form)
#                    or 9x16 (Short) file revealed + title/description copied.
#                    No setup, no quota, no risk. RECOMMENDED to start.
# YT_MODE=api     -> fully automatic upload via the YouTube Data API.
#                    Requires the one-time Google Cloud setup below AND costs
#                    ~1600 of your 10,000 daily quota units per upload (~6/day).
#                    NOTE: until Google verifies your app, API-uploaded videos
#                    may be forced PRIVATE — fine for testing, see the warning
#                    the tool prints.
YT_MODE=assist
# Only needed when YT_MODE=api. Path to the OAuth "Desktop app" client secret
# JSON you download from Google Cloud Console (APIs & Services -> Credentials).
# Enable "YouTube Data API v3", add yourself as a test user on the OAuth consent
# screen, create a Desktop OAuth client, download the JSON, point here:
YT_CLIENT_SECRET_JSON=
# Default privacy for API uploads: private | unlisted | public. Start private.
YT_PRIVACY=private


# ════════════════════════════════════════════════════════════════════════════
#  OPTIONAL EXTRAS — fully AUTO, trivial to set up, zero ban risk.
#  Great low-effort places to also blast each video. All BLANK = all skipped.
# ════════════════════════════════════════════════════════════════════════════

# -- Telegram channel/group (AUTO) ------------------------------------------
# Make a bot via @BotFather (gives a token), add it as admin to your channel,
# then get the chat id (e.g. message the channel, read it from
# https://api.telegram.org/bot<token>/getUpdates, or use @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- Discord (AUTO) ----------------------------------------------------------
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
DISCORD_WEBHOOK_URL=


# ════════════════════════════════════════════════════════════════════════════
#  ASSIST-ONLY platforms (no token needed; pasted here only so you can turn
#  them on/off). Set to 1 to include in a publish run, blank/0 to skip.
#  Each one: opens the upload page + copies the caption + reveals the video.
# ════════════════════════════════════════════════════════════════════════════
ASSIST_YOUTUBE=1
ASSIST_TIKTOK=0
ASSIST_INSTAGRAM=0
ASSIST_LINKEDIN=0
ASSIST_X=0
ASSIST_REDDIT=0
