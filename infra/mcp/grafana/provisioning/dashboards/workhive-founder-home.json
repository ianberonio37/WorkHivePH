{
  "uid": "workhive-founder-home",
  "title": "WorkHive Founder Home",
  "tags": ["workhive", "founder", "home", "ops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "links": [
    { "title": "Founder Ops (detail)", "type": "link", "url": "/d/workhive-founder-ops", "icon": "dashboard", "targetBlank": false },
    { "title": "SLO / Golden Signals", "type": "link", "url": "/d/workhive-slo-arct", "icon": "heart", "targetBlank": false },
    { "title": "DB & Security Health", "type": "link", "url": "/d/workhive-db-health", "icon": "cloud", "targetBlank": false },
    { "title": "Growth", "type": "link", "url": "/d/workhive-growth", "icon": "graph", "targetBlank": false },
    { "title": "App Errors", "type": "link", "url": "/d/workhive-errors", "icon": "bug", "targetBlank": false },
    { "title": "Platform Actions", "type": "link", "url": "http://127.0.0.1:5000/workhive/platform-actions.html", "icon": "bolt", "targetBlank": true }
  ],
  "templating": {
    "list": [
      {
        "name": "hive", "label": "Hive", "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
        "query": "select coalesce(nullif(name,''), id::text) as __text, id::text as __value from hives order by 1",
        "includeAll": true, "allValue": "%", "current": { "text": "All", "value": "$__all" }, "refresh": 2, "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Platform errors (1h)",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select count(*) as value from wh_traces where error_code is not null and coalesce(status,0) not in (401,403,429) and created_at > now() - interval '1 hour'" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Active workers (24h)",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select count(distinct worker_name) as value from analytics_events where worker_name is not null and created_at > now() - interval '24 hours' and hive_id::text like '$hive'" } ]
    },
    {
      "id": 3, "type": "stat", "title": "AI cost (24h)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select coalesce(sum(cost_usd),0) as value from ai_cost_log where created_at > now() - interval '24 hours' and hive_id::text like '$hive'" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Action queue (needs you)",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 5 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select (select count(*) from marketplace_listings where status = 'draft') + (select count(*) from marketplace_sellers where kyb_verified is not true) + (select count(*) from marketplace_disputes where status = 'open') as value" } ]
    },
    {
      "id": 5, "type": "stat", "title": "New hives (7d)",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 5 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select count(*) as value from hives where created_at > now() - interval '7 days'" } ]
    },
    {
      "id": 6, "type": "stat", "title": "Events (24h)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select count(*) as value from analytics_events where created_at > now() - interval '24 hours' and hive_id::text like '$hive'" } ]
    },
    {
      "id": 7, "type": "stat", "title": "Cron jobs failed (24h)",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select count(*) as value from v_cron_health where status = 'failed' and start_time > now() - interval '24 hours'" } ]
    },
    {
      "id": 8, "type": "table", "title": "Recent cron failures (7d)",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 10 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" },
      "description": "Silent scheduled-job failures. pg_cron restricts run history to the job owner, so this reads the postgres-owned public.v_cron_health view. A failing daily job (PM overdue, risk scoring, AI eval) means that automation isn't running.",
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [ { "matcher": { "id": "byName", "options": "failed" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "failed", "desc": true } ] },
      "targets": [ { "refId": "A", "format": "table", "datasource": { "type": "grafana-postgresql-datasource", "uid": "supabase_local" }, "rawSql": "select jobname, schedule, count(*) filter (where status='failed') as failed, max(start_time) filter (where status='failed') as last_failure, max(left(return_message,80)) filter (where status='failed') as last_error from v_cron_health where start_time > now() - interval '7 days' group by jobname, schedule having count(*) filter (where status='failed') > 0 order by failed desc" } ]
    }
  ]
}
