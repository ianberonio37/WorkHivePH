# ─────────────────────────────────────────────────────────────────────
# WorkHive MCP stack secrets — copy to `.env.mcp` (gitignored) and fill.
# Generate strong values for anything marked CHANGE_ME.
#
#   cp infra/mcp/.env.mcp.example infra/mcp/.env.mcp
#   # then edit infra/mcp/.env.mcp
# ─────────────────────────────────────────────────────────────────────

# ── Grafana ────────────────────────────────────────────────────────────
# Web UI: http://127.0.0.1:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin

# Password for the Postgres `grafana_reader` role (read-only on Supabase).
# Must match what you SET in infra/mcp/grafana/grafana_reader.sql.
GRAFANA_PG_READER_PASSWORD=CHANGE_ME_grafana_reader

# ── GlitchTip (self-hosted Sentry-compatible) ──────────────────────────
# Web UI: http://127.0.0.1:8000
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
GLITCHTIP_SECRET_KEY=CHANGE_ME_50_random_chars_minimum
GLITCHTIP_DB_PASSWORD=CHANGE_ME_glitchtip_db

# ── GitHub MCP ─────────────────────────────────────────────────────────
# Generate a fine-grained PAT (READ-ONLY on this repo only):
#   https://github.com/settings/personal-access-tokens/new
# Scopes: Contents=Read, Issues=Read, Pull requests=Read, Metadata=Read
# Save it here so Docker MCP Toolkit can pull it.
GITHUB_PERSONAL_ACCESS_TOKEN=CHANGE_ME_github_pat

# ── Obsidian Local REST API ───────────────────────────────────────────
# After you install the Obsidian app + "Local REST API" community plugin,
# the plugin Settings page shows the API key. Paste it here.
OBSIDIAN_API_KEY=CHANGE_ME_obsidian_local_rest_api_key
OBSIDIAN_HOST=https://127.0.0.1:27124

# ── Postgres MCP (local Supabase) ──────────────────────────────────────
# Read-only Supabase URL. Use the `grafana_reader` role for safety.
# Supabase local DB listens on host port 54322.
POSTGRES_CONNECTION_STRING=postgres://grafana_reader:CHANGE_ME_grafana_reader@host.docker.internal:54322/postgres
