# WorkHive — environment variables
# =================================
# Documents every secret used by Supabase edge functions + the Python API.
# Set these via `supabase secrets set NAME=value` for edge fns, or in a local
# `.env` for python-api. Caught + locked in 2026-05-20 by
# `validate_env_variable_existence.py` — every Deno.env.get('X') /
# process.env.X reference must be listed here so contributors and fresh
# environments know which secrets to provision.

# ── Supabase platform (built-in; provisioned automatically) ──────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=

# ── CORS / origin allowlist ──────────────────────────────────────────────
# Comma-separated origins permitted to call edge functions (e.g.
# https://workhiveph.com,http://localhost:5000). Used by _shared/cors.ts.
ALLOWED_ORIGIN=

# ── AI providers (free-tier chain — see tools/ai_chain.py + _shared/ai-chain.ts) ──
# Each provider is rotated through by callAI; missing keys fall back to the
# next provider transparently. All optional individually; need at least one
# to keep the chain healthy.
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# ── Embeddings (Voyage primary, Jina fallback) ───────────────────────────
# Used by _shared/embedding-chain.ts when ingesting KB / fault knowledge.
VOYAGE_API_KEY=
JINA_API_KEY=

# ── Azure Speech (TTS — Rosa/James voice) ────────────────────────────────
# Free F0 tier shipped 2026-05-13 Phase 7. Used by tts-speak edge fn.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ── Azure Document Intelligence (Equipment label OCR) ────────────────────
# Used by equipment-label-ocr edge fn to extract tag/manufacturer/serial
# from a worker-uploaded label photo.
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# ── Stripe (marketplace payments + connect onboarding) ───────────────────
# Used by marketplace-checkout, marketplace-connect-onboard,
# marketplace-connect-status edge fns.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resend (transactional email — report delivery) ───────────────────────
# Used by send-report edge fn (PDF report delivery from Report Sender UI).
RESEND_API_KEY=

# ── Python API (cluster + ML inference helper) ───────────────────────────
# URL of the Python FastAPI deployed on Render (port 8000). Used by
# analytics-orchestrator, batch-risk-scoring, engineering-calc-agent
# edge fns to delegate heavy compute (KMeans, anomaly detection, calcs).
PYTHON_API_URL=
