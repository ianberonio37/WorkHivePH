# WorkHive — environment variables
# =================================
# Documents every secret used by Supabase edge functions + the Python API.
# Set these via `supabase secrets set NAME=value` for edge fns, or in a local
# `.env` for python-api. Caught + locked in 2026-05-20 by
# `validate_env_variable_existence.py` — every Deno.env.get('X') /
# process.env.X reference must be listed here so contributors and fresh
# environments know which secrets to provision.

# ── Supabase platform (built-in; provisioned automatically) ──────────────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=

# ── CORS / origin allowlist ──────────────────────────────────────────────
# Comma-separated origins permitted to call edge functions (e.g.
# https://workhiveph.com,http://localhost:5000). Used by _shared/cors.ts.
ALLOWED_ORIGIN=

# ── RAG Flywheel rate-limit knobs (agentic-rag-loop edge fn) ─────────────
# Optional per-environment overrides for the in-process token-bucket used
# by the RAG flywheel walks. Defaults: 50 prod / 300 dev. Override raises
# the per-minute ceiling; reset clears the bucket on next request.
WH_RATE_LIMIT_OVERRIDE=
# P1 roadmap 2026-05-26: per-user soft cap inside the per-hive limit (default 25).
WH_USER_RATE_LIMIT_OVERRIDE=
# Phase 0 solo rate limit (resume-builder): always-on IP/auth_uid ceiling for solo (no-hive) callers in _shared/rate-limit.ts. Default 30/hr; raise for synthetic walks.
WH_SOLO_RATE_LIMIT_OVERRIDE=
# Q4 2026-07-05: per-DAY AI ceilings in _shared/rate-limit.ts (alongside the hourly). Defaults: hive 300/day, solo 100/day.
WH_RATE_LIMIT_PER_DAY_OVERRIDE=
WH_SOLO_RATE_LIMIT_PER_DAY_OVERRIDE=
# Solo IP-ceiling multiplier in _shared/rate-limit.ts — the per-IP hard wall for solo (no-hive) callers is this x the per-solo cap. Default 5.
WH_SOLO_IP_CEILING_MULTIPLIER=
# Q6 2026-07-05: GLOBAL org-shared LLM-pool guard in _shared/rate-limit.ts. Defaults: 120 req/min burst-smoother wall, 12000 req/day circuit-breaker. Env-overridable; graceful fallback to defaults if unset.
WH_GLOBAL_RPM=
WH_GLOBAL_RPD=
# P1 roadmap 2026-05-26: structured logger threshold (debug | info | warn | error). Default info.
WH_LOG_LEVEL=
# P1 roadmap 2026-05-27 turn 7: voice quota share inside per-hive bucket (0.0-1.0). Default 0.7.
WH_VOICE_QUOTA_RATIO=
WH_RATE_LIMIT_RESET=
# Arc T/T2 2026-07-01: LOCAL-only fault-injection ("chaos") flag for _shared/observability.ts. When '1', a request carrying the x-wh-fault-inject header throws an unhandled error to prove the error net (wh_traces capture). OFF/unset in prod; a service-role caller can also trigger it (see observability.ts). Never set in production.
WH_CHAOS=

# ── Login lockout (login edge fn — brute-force throttle) ─────────────────
# Env-tunable thresholds in supabase/functions/login/index.ts. Defaults:
# 5 attempts / 15-min window / 15-min lockout. All optional (code defaults).
WH_LOGIN_MAX_ATTEMPTS=
WH_LOGIN_WINDOW_MIN=
WH_LOGIN_LOCKOUT_MIN=

# ── Self-hosted ASR (audio-chain.ts — voice transcription) ───────────────
# Optional Whisper/ASR endpoint. Local auto-defaults to
# http://host.docker.internal:8902/transcribe; prod sets it explicitly or
# leaves it empty to skip the self-hosted lane.
WH_ASR_URL=

# ── AI providers (free-tier chain — see tools/ai_chain.py + _shared/ai-chain.ts) ──
# Each provider is rotated through by callAI; missing keys fall back to the
# next provider transparently. All optional individually; need at least one
# to keep the chain healthy.
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# ── Embeddings (Voyage primary, Jina fallback) ───────────────────────────
# Used by _shared/embedding-chain.ts when ingesting KB / fault knowledge.
VOYAGE_API_KEY=
JINA_API_KEY=

# ── Azure Speech (TTS — Zaniah/Hezekiah voice) ───────────────────────────
# Free F0 tier shipped 2026-05-13 Phase 7. Used by tts-speak edge fn.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ── Azure Document Intelligence (Equipment label OCR) ────────────────────
# Used by equipment-label-ocr edge fn to extract tag/manufacturer/serial
# from a worker-uploaded label photo.
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# ── Resend (transactional email — report delivery) ───────────────────────
# Used by send-report edge fn (PDF report delivery from Report Sender UI).
RESEND_API_KEY=

# ── Python API (cluster + ML inference helper) ───────────────────────────
# URL of the Python FastAPI deployed on Render (port 8000). Used by
# analytics-orchestrator, batch-risk-scoring, engineering-calc-agent
# edge fns to delegate heavy compute (KMeans, anomaly detection, calcs).
PYTHON_API_URL=
# Shared secret sent as the X-API-Key header to the Python API (analytics-
# orchestrator etc.). Default '' (no auth) when unset; set in prod.
PYTHON_API_KEY=

# ── NotebookLM long-form lane (tools/notebooklm_campaign.py) ─────────────
# Unofficial Google NotebookLM SDK — produces podcasts, cinematic videos,
# slide decks, blog posts, infographics, mind maps from each video idea.
# See workflows/notebooklm_long_form.md for full setup.
# Default output language for artifacts. Override per-run with --lang.
NOTEBOOKLM_DEFAULT_LANGUAGE=en
# Path to the saved Playwright storage state. Optional — defaults below.
# NOTEBOOKLM_STORAGE_STATE=.tmp/notebooklm/_session/storage_state.json

# ── Sovereign local LLM (NATIVE_AI_ROADMAP.md #2b; tools/lib/ai_chain.py) ──
# When WH_LLM_URL is set, the AI chain tries the plant's own OpenAI-compatible endpoint
# (Ollama / llama.cpp) FIRST so inference + data stay in-plant, then falls back to the cloud
# chain. All OPTIONAL: unset WH_LLM_URL skips the local lane entirely; model has a code default.
WH_LLM_URL=
WH_LLM_MODEL=llama3.1
WH_LLM_API_KEY=

# ── Edge-function embedding / companion env (set in supabase/functions/.env) ──
# Documented here so validate_env_variable_existence sees them; all OPTIONAL with code defaults.
# Self-hosted bge-small embedding server URL (companion RAG); chain skips bge-local when unset.
BGE_EMBED_URL=http://host.docker.internal:8080
# Embed model id for the persona-knowledge corpus (companion L08); has a code default.
PERSONA_KNOWLEDGE_EMBED_MODEL=bge-small-en-v1.5
# ai-gateway diagnostic echo flag — OFF in prod; gated dev-only debug. Defaults false when unset.
WH_ALLOW_DEBUG_ECHO=false
# Embedding-chain provider preference; defaults to 'voyage' when unset.
EMBEDDING_PRIMARY=voyage
# Cloudflare Workers-AI embed provider (OPTIONAL) — chain skips it when unset (catches + next provider).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
