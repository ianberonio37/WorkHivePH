# Voice Companion Configuration (Phase 0-3)
# Free-tier AI models + embeddings for multi-agent orchestrator

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 1-2: Multi-Model Orchestration
# ─────────────────────────────────────────────────────────────────────────────

# Groq Scout (Primary Model)
# Free tier: 9,000 requests/day, 128 requests/minute
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# Cerebras Qwen (Fallback #1)
# Free tier: 25 requests/minute
# Get key: https://portal.cerebras.ai
CEREBRAS_API_KEY=csk_YOUR_CEREBRAS_KEY_HERE

# Voyage AI (Fallback #2)
# Free tier: generous limits for reasoning tasks
# Get key: https://www.voyage.ai
VOYAGE_API_KEY=YOUR_VOYAGE_KEY_HERE

# Jina AI (Fallback #3 + Embeddings)
# Free tier: 8,000 requests/month
# Used for both LLM fallback and vector embeddings
# Get key: https://jina.ai
# If not set, voice-semantic-rag falls back to recency-based search
JINA_API_KEY=jina_YOUR_JINA_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# MODEL STRATEGY CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Which model strategy to use:
#   scout       = Groq Scout only (default, fastest)
#   qwen        = Cerebras Qwen only
#   sambanova   = SambaNova only
#   round-robin = Try all three in rotation
MODEL_STRATEGY=scout

# Enable AI quality tracking (optional)
# When enabled, logs model performance metrics for A/B testing
AI_EVAL_ENABLED=0

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────

# To enable Phase 1-2 (multi-agent + model fallback):
# 1. Get free-tier API keys from Groq, Cerebras, Voyage, Jina (see URLs above)
# 2. Copy this file to .env and fill in the keys
# 3. Deploy edge functions:
#      supabase/functions/platform-scraper/
#      supabase/functions/voice-semantic-rag/
#      supabase/functions/voice-model-call/
#      supabase/functions/voice-embeddings/
# 4. Update voice-handler.js to use voice-model-call edge function

# To enable Phase 1.5 (semantic RAG with embeddings):
# 1. Get JINA_API_KEY (free tier link above)
# 2. Deploy supabase/functions/voice-embeddings/
# 3. Batch-embed existing voice_journal_entries:
#      python -m tools.embedding_helper < voice_journal_entries.jsonl
# 4. ai-gateway will embed new entries on insert

# ─────────────────────────────────────────────────────────────────────────────
# COST SUMMARY
# ─────────────────────────────────────────────────────────────────────────────

# Phase 1-2:  $0/month (all free tiers)
# Phase 1.5:  $0/month (Jina: 8k req/month free)
# TOTAL:      $0/month production cost

