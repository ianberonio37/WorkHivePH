# Azure $200 / 7-day Foundations Sprint — environment variables
#
# COPY this file to `.env.azure` and fill in the values from Azure Portal.
# `.env.azure` is gitignored. NEVER commit the real file.
#
# All resources should be provisioned in Southeast Asia region (Singapore).

# ---------------------------------------------------------------------------
# Layer 2: Document Intelligence (Read model, $1.50/1000 pages)
# Provision: Azure Portal -> Create resource -> "Document Intelligence" -> S0
# Endpoint format: https://<resource-name>.cognitiveservices.azure.com/
# ---------------------------------------------------------------------------
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# ---------------------------------------------------------------------------
# Layer 3: Custom Vision (4 detectors: defect, arc/spark, smoke/steam, label)
# Provision: Azure Portal -> Create resource -> "Custom Vision" -> S0
# Returns TWO keys (training + prediction) and TWO endpoints (training + prediction)
# ---------------------------------------------------------------------------
AZURE_CUSTOM_VISION_TRAINING_ENDPOINT=
AZURE_CUSTOM_VISION_TRAINING_KEY=
AZURE_CUSTOM_VISION_PREDICTION_ENDPOINT=
AZURE_CUSTOM_VISION_PREDICTION_KEY=
AZURE_CUSTOM_VISION_PREDICTION_RESOURCE_ID=

# ---------------------------------------------------------------------------
# Layer 4 + 6: Azure ML Workspace (audio classifier + noise suppression training)
# Provision: Azure Portal -> Create resource -> "Azure Machine Learning" -> Basic
# Values from the workspace overview page.
# ---------------------------------------------------------------------------
AZURE_ML_SUBSCRIPTION_ID=
AZURE_ML_RESOURCE_GROUP=
AZURE_ML_WORKSPACE_NAME=
AZURE_ML_REGION=southeastasia

# ---------------------------------------------------------------------------
# Layer 7: Translator (Filipino/Tagalog/Cebuano -> English phrase cache)
# Provision: Azure Portal -> Create resource -> "Translator" -> F0 (FREE)
# F0 = 2M chars/month free forever. Our use is ~50K chars, well within.
# ---------------------------------------------------------------------------
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=southeastasia

# ---------------------------------------------------------------------------
# Existing Azure Speech (Persona TTS, already in production at F0)
# Per memory: Speech Key 1 was exposed in a prior chat and is being rotated
# as the first step of Day 1. Update this AFTER regeneration.
# ---------------------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# ---------------------------------------------------------------------------
# Local dataset directory (outside the project repo to avoid git bloat)
# Suggested: c:\wh-datasets  on Windows, ~/wh-datasets on Linux/macOS
# ---------------------------------------------------------------------------
WH_DATASETS_DIR=c:\wh-datasets
