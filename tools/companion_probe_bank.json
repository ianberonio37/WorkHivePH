        "asset": ["motor M-101", "blower BL-22", "feed pump FP-7", "exhaust fan EF-12", "drive D-44"],
        "value": ["18", "62", "104", "210", "37"],
        "unit": ["amps", "kW", "RPM", "bar", "degrees Celsius"],
        "adj": ["high", "low", "unusual", "off", "different"]
      },
      "expected_route": "voice-journal-agent",
      "expected_keywords_any": ["check", "trend", "anomaly", "compare", "history", "investigate", "look"],
      "category": "held_out_analytics"
    },
